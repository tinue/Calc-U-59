# run pressing A
# text "598-TEST-1" is printed
# runs 2:55
# shows default memory partitioning
# in case of faulty RAM, "strange" info is printed:
# (example from program output for TI-58)
#     1212.   ?  99
#     1211.   ?  98
#     1210.   ?  97
#     1207.   ?  96
# ...
#      401.   ?  30
# on TI-58, it finishes with 0.59 blinking...
# ------------------------


PROGRAM:
000	76	LBL
001	11	 A
002	00	 0
003	06	 6
004	01	 1
005	02	 2
006	01	 1
007	01	 1
008	02	 2
009	00	 0
010	03	 3
011	07	 7
