012	69	OP
013	02	 02
014	01	 1
015	07	 7
016	03	 3
017	06	 6
018	03	 3
019	07	 7
020	02	 2
021	00	 0
022	00	 0
023	02	 2
# "EST-1"
024	69	OP
025	03	 03
# print buffer
026	69	OP
027	05	 05
# set memory partitioning: 100 registers, 160 program steps
# TI-58: not accepted#  239.29 shows blinking on display
#        4 Op 17 (or 04 Op 17) should be here
028	01	 1
029	00	 0
030	69	OP
031	17	 17
# clear memories
032	47	CMS
# initialize variables
# starting register index - 1
033	03	 3
034	42	STO
035	00	 00
# initialization value to be stored and checked again
036	09	 9
037	35	1/X
038	42	STO
039	01	 01
# register count
